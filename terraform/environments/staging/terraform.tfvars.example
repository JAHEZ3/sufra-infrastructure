# Copy to terraform.tfvars and adjust. terraform.tfvars is gitignored.

project     = "sufra"
environment = "staging"
aws_region  = "us-east-1"

# Networking
vpc_cidr             = "10.20.0.0/16"
availability_zones   = ["us-east-1a", "us-east-1b"]
public_subnet_cidrs  = ["10.20.0.0/24", "10.20.1.0/24"]
private_subnet_cidrs = ["10.20.10.0/24", "10.20.11.0/24"]

# Environment behavior - staging mirrors prod safety, keeps some cost savings
single_nat_gateway     = true
s3_force_destroy       = false
db_multi_az            = false
db_deletion_protection = true
db_skip_final_snapshot = false
cache_num_nodes        = 2

# DNS / TLS
enable_dns  = false
domain_name = "staging.sufra.com"

# EKS
cluster_version = "1.30"
node_groups = {
  general = {
    instance_types = ["t3.large"]
    desired_size   = 2
    min_size       = 2
    max_size       = 4
  }
}

# ECR
ecr_repositories = ["api", "web", "worker"]

# RDS
db_engine_version = "16.3"
db_instance_class = "db.t3.small"
db_name           = "sufra"

# ElastiCache
cache_node_type = "cache.t3.small"

# Observability
alarm_email_endpoints = ["ops@sufra.com"]
